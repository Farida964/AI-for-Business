      "parameters": {
        "jsCode": "const rawText = $json.text;\n\n// ambil JSON antara { sampai }\nconst match = rawText.match(/\\{[\\s\\S]*\\}/);\n\nif (!match) {\n  throw new Error(\"JSON tidak ditemukan\");\n}\n\ntry {\n  const jsonData = JSON.parse(match[0]);\n  return [{ json: jsonData }];\n} catch (error) {\n  throw new Error(\"Parse JSON gagal: \" + error);\n}"
      },
