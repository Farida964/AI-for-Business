        "jsCode": "const data = $json;\n\nconst technical = Number(data.it_difficulty_score || 0);\nconst teaching = Number(data.teaching_score || 0);\n\nconst finalScore = Math.round((technical * 0.7) + (teaching * 0.3));\n\nconst status = finalScore >= 7 ? \"Lolos\" : \"Tidak Lolos\";\n\nreturn [{\n  json: {\n    ...data,\n    final_score: finalScore,\n    status\n  }\n}];"
