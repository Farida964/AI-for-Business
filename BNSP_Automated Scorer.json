    {
      "parameters": {
        "jsCode": "let html = $json.body || $json.data || $json.html || \"\";\n\n// =========================\n// REMOVE SCRIPT & STYLE\n// =========================\nhtml = html\n  .replace(/<script[\\s\\S]*?<\\/script>/gi, '')\n  .replace(/<style[\\s\\S]*?<\\/style>/gi, '')\n  .replace(/<meta[\\s\\S]*?>/gi, '')\n  .replace(/<head[\\s\\S]*?<\\/head>/gi, '');\n\n// =========================\n// LIST ITEMS\n// =========================\nhtml = html\n  .replace(/<li[^>]*>/gi, '\\n- ')\n  .replace(/<\\/li>/gi, '');\n\n// =========================\n// PARAGRAPH & BREAKS\n// =========================\nhtml = html\n  .replace(/<\\/p>/gi, '\\n')\n  .replace(/<br\\s*\\/?>/gi, '\\n')\n  .replace(/<\\/div>/gi, '\\n')\n  .replace(/<\\/tr>/gi, '\\n');\n\n// =========================\n// REMOVE HTML TAGS\n// =========================\nhtml = html.replace(/<[^>]+>/g, ' ');\n\n// =========================\n// REMOVE PAGE NUMBER\n// =========================\nhtml = html.replace(/Page \\d+ of \\d+/gi, '');\nhtml = html.replace(/\\bPage\\s*\\d+\\b/gi, '');\nhtml = html.replace(/^\\s*\\d+\\s*$/gm, '');\n\n// =========================\n// REMOVE COMMON FOOTER\n// =========================\nhtml = html.replace(/©.*\\n/gi, '');\nhtml = html.replace(/All rights reserved.*/gi, '');\n\n// =========================\n// KEEP IMPORTANT TITLES\n// =========================\nhtml = html.replace(\n  /Curriculum Vitae|Resume|CV/gi,\n  (m) => `\\n${m}\\n`\n);\n\n// =========================\n// HTML ENTITIES\n// =========================\nhtml = html\n  .replace(/&nbsp;/g, ' ')\n  .replace(/&amp;/g, '&')\n  .replace(/&lt;/g, '<')\n  .replace(/&gt;/g, '>')\n  .replace(/&quot;/g, '\"')\n  .replace(/&#39;/g, \"'\");\n\n// =========================\n// REMOVE EXTRA SYMBOLS\n// =========================\nhtml = html\n  .replace(/[■▪•●]/g, '-')\n  .replace(/[^\\x20-\\x7E\\n]/g, ' ');\n\n// =========================\n// NORMALIZE SPACES\n// =========================\nhtml = html\n  .replace(/\\n\\s*\\n\\s*\\n+/g, '\\n\\n')\n  .replace(/[ \\t]+/g, ' ')\n  .replace(/\\s+\\n/g, '\\n')\n  .replace(/\\n\\s+/g, '\\n')\n  .trim();\n\n// =========================\n// VALIDATION\n// =========================\nif (!html || html.length < 50) {\n  return [{\n    json: {\n      clean_text: \"\",\n      parse_status: \"FAILED\"\n    }\n  }];\n}\n\n// =========================\n// SUCCESS\n// =========================\nreturn [{\n  json: {\n    clean_text: html,\n    parse_status: \"SUCCESS\"\n  }\n}];"
      },
